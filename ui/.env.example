# EVM endpoint. Theseus exposes Ethereum-compatible JSON-RPC via the
# `eth-rpc` proxy (PolkaVM under the hood). Default 8545 to match the
# pattern in github.com/Theseuschain/theseus-layerzero-evm.
NEXT_PUBLIC_EVM_RPC=http://127.0.0.1:8545
NEXT_PUBLIC_CHAIN_ID=420420420

# Substrate endpoint (server-side only — not exposed to the browser)
THESEUS_WS=ws://127.0.0.1:9944

# Admin signing seed for tamper / reset extrinsics. Dev: //Alice.
# Server-side only.
ADMIN_SEED=//Alice

# Deployment addresses. Filled in by scripts/setup_demo.sh.
NEXT_PUBLIC_AGENT_PRICE_FEED=
NEXT_PUBLIC_POOL=
NEXT_PUBLIC_WETH=
NEXT_PUBLIC_USDC=
NEXT_PUBLIC_AGENT_ID=

# Optional: WalletConnect project ID for the Connect button. Get one at
# https://cloud.walletconnect.com if you want WC-compatible wallets.
NEXT_PUBLIC_WC_PROJECT_ID=

# DeepSeek API key for the LLM-backed agent. When unset, the "DeepSeek" mode
# in the UI will return 503 and the demo falls back to the rule-based agent.
# Server-side only. Mark as Sensitive on Vercel.
DEEPSEEK_API_KEY=

# Optional: keyed Ethereum mainnet RPC for the Uniswap V3 reader. When unset,
# falls back to a chain of public RPCs (blastapi → ankr → cloudflare → llama).
MAINNET_RPC=

# --- Launch sniper agent (paper-trading on Base Sepolia) ---
# Anthropic API key for the Launch Sniper evaluator (Claude Haiku 4.5).
# Server-side only. Mark as Sensitive on Vercel.
ANTHROPIC_API_KEY=

# Private key (0x-prefixed hex) for the Launch Sniper agent EOA. Signs
# tick() calls on the LaunchSniperFund contract on Base Sepolia. Same
# centralized agent EOA as SovereignFund. Server-side only. Sensitive.
AGENT_PRIVATE_KEY=

# Optional: keyed Base mainnet RPC for the launch indexer's eth_getLogs
# scans. When unset, falls back to https://mainnet.base.org.
BASE_MAINNET_RPC=

# Optional: keyed Base Sepolia RPC for the executor's tick() calls. When
# unset, falls back to https://sepolia.base.org.
BASE_SEPOLIA_RPC=

# Vercel Blob credential for publishing reasoning blobs. The executor
# writes the full dossier + decision JSON to blob storage under
# `launch-sniper/<reasonHash>.json` and the on-chain reasonHash points
# at it. Get the token from Vercel: Project → Storage → Blob → "Create
# new token". When unset, blobs aren't published but ticks still post.
BLOB_READ_WRITE_TOKEN=

# Public base URL of the Vercel Blob store. Used by the viewer to build
# blob URLs from on-chain reason hashes without a separate lookup.
# Format: https://<store-id>.public.blob.vercel-storage.com
BLOB_PUBLIC_BASE_URL=

# Etherscan V2 API key (works across all chains, including Base mainnet
# chainid=8453). Required for the Launch Sniper Phase 2 dossier:
# source-verification + deployer history + top-10 holder concentration.
# Without it, those fields surface to the LLM as "unknown" and the
# agent will continue to PASS on every launch (its safe default).
# Get a free key at https://etherscan.io/myapikey.
ETHERSCAN_API_KEY=

# Brave Search API key for the Launch Sniper narrative-research step.
# Free tier: 2,000 queries/month, plenty for the agent's gated volume.
# Get a key at https://brave.com/search/api/. Without it, the
# narrative block in the dossier surfaces as "research unavailable"
# and the agent decides on tokenomics alone (its previous behavior).
BRAVE_SEARCH_API_KEY=


# =============================================================================
# Theseus on-chain agent integration (currently placeholder — set when
# the public chain + 13 demo agents are deployed).
# =============================================================================
#
# When these are set, demo pages display a "Theseus on-chain · <ss58>"
# pill that links to the chain explorer, and the demo route can submit
# the user's prompt to the real on-chain agent instead of the
# centralized DeepSeek call. Left unset (the default), each demo page
# shows "Theseus on-chain · coming soon" and the existing centralized
# flow runs unchanged.
#
# Bundled to the browser at build time. Restart `next dev` after
# changing any of these.

# WS RPC URL of the Theseus chain.
NEXT_PUBLIC_THESEUS_RPC=

# Per-demo agent SS58 addresses. One per slug. See
# `ui/src/lib/theseus-onchain/config.ts` for the full list.
NEXT_PUBLIC_THESEUS_AGENT_VELLUM=
NEXT_PUBLIC_THESEUS_AGENT_CALDER=
NEXT_PUBLIC_THESEUS_AGENT_MARCELLUS=
NEXT_PUBLIC_THESEUS_AGENT_APERTURE=
NEXT_PUBLIC_THESEUS_AGENT_QUILL=
NEXT_PUBLIC_THESEUS_AGENT_AAVE=
NEXT_PUBLIC_THESEUS_AGENT_TERRA=
NEXT_PUBLIC_THESEUS_AGENT_BRIDGE=
NEXT_PUBLIC_THESEUS_AGENT_GOVERNANCE=
NEXT_PUBLIC_THESEUS_AGENT_AVIATION=
NEXT_PUBLIC_THESEUS_AGENT_FUND=
NEXT_PUBLIC_THESEUS_AGENT_ADJUDICATE=
NEXT_PUBLIC_THESEUS_AGENT_LAUNCH_SNIPER=

# Server-side signer for `pallet_agents.call` extrinsics. Defaults to
# //Alice in dev. **Mark as Sensitive on Vercel if you ever switch
# this to a real funded account.**
THESEUS_SIGNER_SEED=
